# LLM API Configuration (required for inference.py)
OPENAI_API_KEY=your_groq_or_openai_key_here
API_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.1-8b-instant

# Environment URL
ENV_URL=http://localhost:8000

# Optional: enable LLM grader
ANTHROPIC_API_KEY=your_anthropic_key_here

# Get free Groq key at: https://console.groq.com
# Groq models: llama-3.1-8b-instant, llama3-8b-8192, mixtral-8x7b-32768
